{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@wireapp/api-client/lib/*": ["libraries/api-client/src/*"],
      "@wireapp/api-client/lib": ["libraries/api-client/src/apiClient.ts"],
      "@wireapp/api-client": ["libraries/api-client/src/apiClient.ts"],
      "@wireapp/certificate-check/lib/*": ["libraries/certificate-check/src/*"],
      "@wireapp/certificate-check/lib": ["libraries/certificate-check/src/index.ts"],
      "@wireapp/certificate-check": ["libraries/certificate-check/src/index.ts"],
      "@wireapp/commons/lib": ["libraries/commons/src/index.ts"],
      "@wireapp/commons/lib/*": ["libraries/commons/src/*"],
      "@wireapp/commons": ["libraries/commons/src/index.ts"],
      "@wireapp/config/lib/*": ["libraries/config/src/*"],
      "@wireapp/config/lib": ["libraries/config/src/index.ts"],
      "@wireapp/config": ["libraries/config/src/index.ts"],
      "@wireapp/copy-config/lib/*": ["libraries/copy-config/src/*"],
      "@wireapp/copy-config/lib": ["libraries/copy-config/src/index.ts"],
      "@wireapp/copy-config": ["libraries/copy-config/src/index.ts"],
      "@wireapp/core/lib/*": ["libraries/core/src/*"],
      "@wireapp/core/lib": ["libraries/core/src/index.ts"],
      "@wireapp/core": ["libraries/core/src/index.ts"],
      "@wireapp/license-collector/lib/*": ["libraries/license-collector/src/*"],
      "@wireapp/license-collector/lib": ["libraries/license-collector/src/index.ts"],
      "@wireapp/license-collector": ["libraries/license-collector/src/index.ts"],
      "@wireapp/priority-queue/lib/*": ["libraries/priority-queue/src/*"],
      "@wireapp/priority-queue/lib": ["libraries/priority-queue/src/index.ts"],
      "@wireapp/priority-queue": ["libraries/priority-queue/src/index.ts"],
      "@wireapp/promise-queue/lib/*": ["libraries/promise-queue/src/*"],
      "@wireapp/promise-queue/lib": ["libraries/promise-queue/src/index.ts"],
      "@wireapp/promise-queue": ["libraries/promise-queue/src/index.ts"],
      "@wireapp/react-ui-kit/lib/*": ["libraries/react-ui-kit/src/*"],
      "@wireapp/react-ui-kit/lib": ["libraries/react-ui-kit/src/index.ts"],
      "@wireapp/react-ui-kit": ["libraries/react-ui-kit/src/index.ts"],
      "@wireapp/store-engine/lib/*": ["libraries/store-engine/src/*"],
      "@wireapp/store-engine/lib": ["libraries/store-engine/src/index.ts"],
      "@wireapp/store-engine": ["libraries/store-engine/src/index.ts"],
      "@wireapp/store-engine-dexie/lib/*": ["libraries/store-engine-dexie/src/*"],
      "@wireapp/store-engine-dexie/lib": ["libraries/store-engine-dexie/src/index.ts"],
      "@wireapp/store-engine-dexie": ["libraries/store-engine-dexie/src/index.ts"],
      "@wireapp/store-engine-fs/lib/*": ["libraries/store-engine-fs/src/*"],
      "@wireapp/store-engine-fs/lib": ["libraries/store-engine-fs/src/index.ts"],
      "@wireapp/store-engine-fs": ["libraries/store-engine-fs/src/index.ts"],
      "@wireapp/telemetry/lib/*": ["libraries/telemetry/src/*"],
      "@wireapp/telemetry/lib": ["libraries/telemetry/src/index.ts"],
      "@wireapp/telemetry": ["libraries/telemetry/src/index.ts"],
      "@wireapp/webapp-events/lib/*": ["libraries/webapp-events/src/*"],
      "@wireapp/webapp-events/lib": ["libraries/webapp-events/src/index.ts"],
      "@wireapp/webapp-events": ["libraries/webapp-events/src/index.ts"],
      "bazinga64": ["libraries/bazinga64/src/index.ts"]
    }
  },
  "include": [
    "apps/*/src/**/*",
    "apps/*/test/**/*",
    "libraries/*/src/**/*",
    "libraries/core/jest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "tmp",
    "apps/server/dist",
    "apps/webapp/dist",
    "libraries/core/lib",
    "libraries/core/.tmp",
    "libraries/api-client/lib",
    "libraries/api-client/.tmp"
  ],
  "references": [
    { "path": "./apps/webapp" },
    { "path": "./apps/server" },
    { "path": "./libraries/core" },
    { "path": "./libraries/api-client" }
  ]
}
