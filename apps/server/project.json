{
  "name": "server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "{projectRoot}",
  "projectType": "application",
  "targets": {
    "generate-build-metadata": {
      "executor": "nx:run-commands",
      "dependsOn": ["config-lib:build"],
      "inputs": ["production", "webappBuildMetadata"],
      "outputs": ["{projectRoot}/build/metadata/version.json"],
      "cache": false,
      "options": {
        "commands": ["rimraf {projectRoot}/build/metadata", "WIRE_WEBAPP_BUILD_METADATA_PATH={projectRoot}/build/metadata/version.json node {projectRoot}/bin/generateVersionFile.mts"],
        "parallel": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "telemetry-lib:build"],
      "inputs": ["production"],
      "outputs": ["{projectRoot}/build/server"],
      "options": {
        "commands": [
          "rimraf {projectRoot}/build/server",
          "tsc -p {projectRoot}/tsconfig.json --outDir {projectRoot}/build/server",
          "WIRE_WEBAPP_SERVER_OUTPUT_PATH={projectRoot}/build/server node {projectRoot}/bin/copy_server_assets.js"
        ],
        "parallel": false
      }
    },
    "build-dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["config-lib:build", "generate-build-metadata", "telemetry-lib:build"],
      "inputs": ["production", "webappBuildMetadata"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "rimraf {projectRoot}/dist",
          "tsc -p {projectRoot}/tsconfig.json",
          "node {projectRoot}/bin/copy_server_assets.js",
          "cp {projectRoot}/build/metadata/version.json {projectRoot}/dist/version.json"
        ],
        "parallel": false
      }
    },
    "assemble": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", {"projects": "webapp", "target": "build"}, "generate-build-metadata"],
      "outputs": ["{projectRoot}/dist"],
      "cache": false,
      "options": {
        "command": "node {projectRoot}/bin/assembleBuild.mts internal artifact"
      }
    },
    "assemble-public": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", {"projects": "webapp", "target": "build-production-public"}, "generate-build-metadata"],
      "outputs": ["{projectRoot}/dist"],
      "cache": false,
      "options": {
        "command": "node {projectRoot}/bin/assembleBuild.mts public artifact"
      }
    },
    "assemble-webapp": {
      "executor": "nx:run-commands",
      "dependsOn": [{"projects": "webapp", "target": "build"}, "generate-build-metadata"],
      "outputs": ["{projectRoot}/dist"],
      "cache": false,
      "options": {
        "command": "node {projectRoot}/bin/assembleBuild.mts internal webapp"
      }
    },
    "assemble-webapp-development": {
      "executor": "nx:run-commands",
      "dependsOn": [{"projects": "webapp", "target": "build-development"}, "generate-build-metadata"],
      "outputs": ["{projectRoot}/dist"],
      "cache": false,
      "options": {
        "command": "node {projectRoot}/bin/assembleBuild.mts development webapp"
      }
    },
    "assemble-webapp-public": {
      "executor": "nx:run-commands",
      "dependsOn": [{"projects": "webapp", "target": "build-production-public"}, "generate-build-metadata"],
      "outputs": ["{projectRoot}/dist"],
      "cache": false,
      "options": {
        "command": "node {projectRoot}/bin/assembleBuild.mts public webapp"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["assemble"],
      "inputs": ["production", "webappBuildMetadata"],
      "cache": false,
      "options": {
        "commands": ["node bin/zip.js"],
        "parallel": false
      }
    },
    "package-public": {
      "executor": "nx:run-commands",
      "dependsOn": ["assemble-public"],
      "inputs": ["production", "webappBuildMetadata"],
      "cache": false,
      "options": {
        "commands": ["yarn verify:bundle:prod:public", "node bin/zip.js"],
        "parallel": false
      }
    },
    "serve": {
      "continuous": true,
      "dependsOn": ["config-lib:build", "webapp:build-libs", "webapp:watch-deps-dynamic"],
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "server:build-dev",
        "buildTargetOptions": {
          "outputPath": "{projectRoot}/dist",
          "outputFileName": "index.js"
        },
        "watch": true
      },
      "configurations": {
        "production": {
          "buildTarget": "server:build"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/server"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true,
          "coverageReporters": ["html", "lcov", "text"]
        }
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --config eslint.config.ts --cache --cache-location node_modules/.cache/eslint/server --max-warnings=1289 --ext .js,.ts {projectRoot}"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["config-lib:build"],
      "options": {
        "commands": ["tsc --project {projectRoot}/tsconfig.json --noEmit", "tsc --project {projectRoot}/bin/tsconfig.json --noEmit"],
        "parallel": false
      }
    }
  },
  "tags": ["type:app", "scope:backend"]
}
