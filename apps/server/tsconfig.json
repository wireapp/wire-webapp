{
  "extends": "../../tsconfig.base.json",
  "references": [{"path": "../../libraries/config"}],
  "compilerOptions": {
    "module": "commonjs",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@enormora/objectory": ["node_modules/@enormora/objectory/main.d.ts"]
    },
    "removeComments": true,
    "lib": ["esnext"],
    "noEmitOnError": true,
    "rootDir": ".",
    "target": "es2017",
    "types": ["node", "jest"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
