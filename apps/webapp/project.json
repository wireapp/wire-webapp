{
  "name": "webapp",
  "$schema": "{projectRoot}/node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "{projectRoot}/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist/internal"],
      "dependsOn": ["^build", "server:generate-build-metadata"],
      "inputs": ["production", "webappBuildMetadata", "{workspaceRoot}/apps/server/build/metadata/version.json"],
      "options": {
        "command": "WIRE_WEBAPP_BUILD_METADATA_PATH=apps/server/build/metadata/version.json WIRE_WEBAPP_BUILD_OUTPUT_PATH=apps/webapp/dist/internal yarn build:prod",
        "cwd": "{projectRoot}"
      }
    },
    "build-development": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist/development"],
      "dependsOn": ["^build", "server:generate-build-metadata"],
      "inputs": ["production", "webappBuildMetadata", "{workspaceRoot}/apps/server/build/metadata/version.json"],
      "options": {
        "command": "WIRE_WEBAPP_BUILD_METADATA_PATH=apps/server/build/metadata/version.json WIRE_WEBAPP_BUILD_OUTPUT_PATH=apps/webapp/dist/development yarn build:dev",
        "cwd": "{projectRoot}"
      }
    },
    "build-production-public": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist/public"],
      "dependsOn": ["^build", "server:generate-build-metadata"],
      "inputs": ["production", "webappBuildMetadata", "{workspaceRoot}/apps/server/build/metadata/version.json"],
      "options": {
        "command": "WIRE_WEBAPP_BUILD_METADATA_PATH=apps/server/build/metadata/version.json WIRE_WEBAPP_BUILD_OUTPUT_PATH=apps/webapp/dist/public yarn build:prod:public",
        "cwd": "{projectRoot}"
      }
    },
    "watch-deps": {
      "continuous": true,
      "dependsOn": ["^watch"],
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Watching upstream library dependencies' && tail -f /dev/null",
        "cwd": "{projectRoot}"
      }
    },
    "build-libs": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'All libraries built'",
        "cwd": "{projectRoot}"
      }
    },
    "watch-deps-dynamic": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "[ -n \"$WATCH_LIBS\" ] && nx run-many -t watch --projects=$WATCH_LIBS || tail -f /dev/null",
        "cwd": "{projectRoot}"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "echo 'Use yarn start from the root to run the dev server with webpack-dev-middleware'"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/webapp"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.ts",
        "passWithNoTests": false
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true,
          "coverageReporters": ["html", "lcov", "text"]
        }
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "playwright test --config {projectRoot}/playwright.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "options": {
        "command": "eslint --config eslint.config.ts --max-warnings=758 --cache --cache-location node_modules/.cache/eslint/webapp --ext .js,.ts,.tsx {projectRoot}/src"
      }
    },
    "lint:full": {
      "executor": "nx:run-commands",
      "dependsOn": ["stylelint", "type-check", "lint"],
      "options": {
        "command": "echo 'Full lint checks complete'"
      }
    },
    "stylelint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --ignore-path {projectRoot}/.prettierignore --check \"**/*.less\" && stylelint --ignore-path {projectRoot}/.gitignore \"**/*.less\"",
        "cwd": "{projectRoot}"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc --project {projectRoot}/tsconfig.build.json --noEmit"
      }
    },
    "check-circular": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dpdm --no-warning --no-tree -T {projectRoot}/src/script/auth/main.tsx {projectRoot}/src/script/main/app.ts"
      }
    },
    "translate-extract": {
      "executor": "nx:run-commands",
      "options": {
        "command": "i18next-scanner 'src/{page,script}/**/*.{js,html,htm}'",
        "cwd": "{projectRoot}"
      }
    },
    "translate-merge": {
      "executor": "nx:run-commands",
      "options": {
        "command": "formatjs extract --format './bin/translations_extract_formatter.js' --out-file './src/i18n/en-US.json' 'src/**/*.{ts,tsx,js,jsx}' --ignore 'src/**/*.d.ts' --additional-function-names t",
        "cwd": "{projectRoot}"
      }
    },
    "configure": {
      "executor": "nx:run-commands",
      "dependsOn": ["copy-config-lib:build"],
      "options": {
        "command": "copy-config ./.copyconfigrc.js && ts-node ./bin/generate_react_icons.ts",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:app", "scope:frontend"]
}
