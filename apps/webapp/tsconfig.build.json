{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "Components/*": ["./src/script/components/*"],
      "Hooks/*": ["./src/script/hooks/*"],
      "I18n/*": ["./src/i18n/*"],
      "Repositories/*": ["./src/script/repositories/*"],
      "Resource/*": ["./resource/*"],
      "Util/*": ["./src/script/util/*"],
      "apps/*": ["apps/*"],
      "bazinga64": ["../../libraries/bazinga64/src/index.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "../server/",
    "src/sw.js",
    "src/worker/",
    "src/**/*.mocks.ts",
    "src/**/test/**",
    "src/**/testSupport/**",
    "test/unit_tests/**",
    "test/helper/**",
    "**/*.test.*"
  ]
}
